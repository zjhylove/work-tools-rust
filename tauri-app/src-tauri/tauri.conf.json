{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Work Tools",
  "version": "1.0.0",
  "identifier": "com.zj.worktools",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Work Tools",
        "width": 1200,
        "height": 800
      }
    ],
    "withGlobalTauri": true,
    "security": {
      "csp": null,
      "devCsp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
